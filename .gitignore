# ── Autech LevelPlay Mediation ────────────────────────────────────
# Layout mirrors the Autech AdMob package:
#   • repo root Runtime/, Editor/, Samples~/, package.json  -> distributed package
#   • Assets/LevelPlay/  -> editable / testable working copy (TRACKED)
#   • Packages/manifest.json, ProjectSettings/  -> dev project (TRACKED, so it opens)
# Releases (.unitypackage) go to GitHub Releases, not the repo.

# Unity-generated / machine-local
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]serSettings/
[Mm]emoryCaptures/
.utmp/

# IDE / OS
.vs/
.vscode/
.idea/
.bezisidekick/
*.csproj
*.sln
*.suo
*.user
.DS_Store
Thumbs.db
Desktop.ini

# Release artifacts (publish to GitHub Releases, do not commit)
releases/
dist/
*.unitypackage
*.tgz

# node (if tooling is added later)
node_modules/

# External Dependency Manager (EDM4U) is provided by the LevelPlay SDK — never
# vendor a loose copy here (a duplicate causes a fatal "multiple precompiled
# assemblies" error).
Assets/MobileDependencyResolver/
Assets/MobileDependencyResolver.meta
Assets/ExternalDependencyManager/
Assets/ExternalDependencyManager.meta
Assets/PlayServicesResolver/
Assets/PlayServicesResolver.meta

# UPM hidden folders must stay tracked (in case a global gitignore matches *~)
!*~/
!**/Samples~/**
!**/Documentation~/**

# LevelPlay SDK generates its EDM4U adapter dependency XMLs into Assets/LevelPlay
# (IronSourceSDKDependencies.xml, LevelPlayVersions.json, ...). SDK-owned/generated —
# our editable copy lives in Assets/AutechLevelPlay.
Assets/LevelPlay/
Assets/LevelPlay.meta
